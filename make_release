#!/usr/bin/env bash
set -euo pipefail

# Usage: ./make_release [next|major|minor|patch|<x.y.z>]
MODE="${1:-next}"

case "$MODE" in
  next|major|minor|patch)
    TAG="$(svu "$MODE")"
    ;;
  *)
    TAG="${MODE#v}"
    TAG="v$TAG"
    ;;
esac

VERSION="${TAG#v}"

sed -i "s/^version = .*/version = \"$VERSION\"/" pyproject.toml

git add pyproject.toml
git commit -sm "bump to $VERSION" || true
if [[ ! -v NO_TAG ]]; then
  git tag "$TAG"
  git push origin "$TAG"
fi
git push origin HEAD

echo "$VERSION"
